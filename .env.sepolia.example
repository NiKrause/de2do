# Copy to `.env.sepolia` and fill in. Used by `npm run deploy:sepolia` (sourced by scripts/deploy-sepolia.sh)
# and by Vite when you build with `--mode sepolia` (see README / HOWTO).

# --- Deployer (Foundry) — needs Sepolia ETH for gas ---
PRIVATE_KEY=0x_your_deployer_private_key

# --- RPC (required for deploy + app) ---
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
# Same URL is exposed to the browser as VITE_RPC_URL:
VITE_RPC_URL=https://ethereum-sepolia.publicnode.com
# Public endpoints (e.g. publicnode.com) rate-limit heavily (≈600 req/min). If you see HTTP 429s,
# use a provider key URL (Infura, Alchemy, QuickNode) or a PublicNode personal token URL:
# https://www.allnodes.com/publicnode

# --- Chain + contracts (fill VITE_* after deployment; script prints the values) ---
VITE_CHAIN_ID=11155111
# Public Sepolia test USDT (6 decimals) — same as DeploySepolia.s.sol suggests; change if you use another ERC-20:
VITE_USDT_ADDRESS=0x7169D38820dfd117C3FA1f22a697dBA58d90BA06
VITE_ENTRY_POINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108
VITE_IMPLEMENTATION_CONTRACT=
VITE_ESCROW_CONTRACT=

# --- ERC-4337 stack (bundler / paymaster — use your Openfort/Pimlico Sepolia URLs) ---
VITE_BUNDLER_URL=
# Hosted bundlers often require Authorization (e.g. Pimlico: Bearer YOUR_API_KEY from the dashboard)
# VITE_BUNDLER_AUTH_HEADER=Bearer
VITE_ENABLE_PAYMASTER=false
# VITE_PAYMASTER_URL=
# If the paymaster endpoint also requires auth:
# VITE_PAYMASTER_AUTH_HEADER=Bearer

# Rare: bootstrap passkey account via bundler UserOp + eip7702Auth (bundler must support it).
# Leave unset: bootstrap uses an EIP-7702 type-4 tx on VITE_RPC_URL (needed for Openfort’s bundler).
# VITE_PASSKEY_BOOTSTRAP_VIA_USEROP=1

# Optional: contract verification on Etherscan when running deploy
# ETHERSCAN_API_KEY=

# Optional overrides (see contracts/script/DeploySepolia.s.sol)
# FEE_RECIPIENT=0x...
# FEE_BPS=1500
# Set to 1 only if you skip deploying the mock and use Openfort’s implementation in VITE_IMPLEMENTATION_CONTRACT:
# SEPOLIA_SKIP_MOCK_IMPLEMENTATION=1
