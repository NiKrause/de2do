# Local passkey / AA stack (Anvil + Docker Alto) — copy to `.env.development`
# EntryPoint: ERC-4337 v0.8 only for this app (see docs/HOWTO_PASSKEY_ESCROW.md)
#
# Or auto-fill: start `anvil`, then `pnpm run setup:local-aa` (writes this file’s keys into .env.development)

VITE_CHAIN_ID=31337
VITE_RPC_URL=http://127.0.0.1:8545
# Use Vite dev proxy if you hit CORS: http://localhost:5173/__bundler — see src/lib/chain/config.js
VITE_BUNDLER_URL=http://127.0.0.1:4337

# EntryPoint v0.8 (must match bundler eth_supportedEntryPoints + forge ENTRY_POINT_ADDRESS)
VITE_ENTRY_POINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108

# After: forge script contracts/script/DeployMockOpenfort7702Implementation.s.sol --broadcast
VITE_IMPLEMENTATION_CONTRACT=

# After: forge script contracts/script/DeployEscrow.s.sol --broadcast
VITE_ESCROW_CONTRACT=

# After: forge script contracts/script/DeployMockUSDT.s.sol --broadcast
VITE_USDT_ADDRESS=

VITE_ENABLE_PAYMASTER=false
# VITE_PAYMASTER_URL=http://127.0.0.1:3002

# Optional: in-app "Fund smart account" on Anvil (disposable key only)
# VITE_LOCAL_DEV_FUNDER_PRIVATE_KEY=
