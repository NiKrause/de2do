# Playwright + `vite preview --mode test` — copy to `.env.test`
# Same AA contract addresses as local dev after you deploy to Anvil.
# Start: anvil, docker compose -f docker-compose.aa-local.yml up -d, forge scripts, then pnpm run preview:test

VITE_CHAIN_ID=31337
VITE_RPC_URL=http://127.0.0.1:8545
VITE_BUNDLER_URL=http://127.0.0.1:4337

VITE_ENTRY_POINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108
VITE_IMPLEMENTATION_CONTRACT=0x1fa02b2d6a771842690194cf62d91bdd92bfe28d
VITE_ESCROW_CONTRACT=0xdbc43ba45381e02825b14322cddd15ec4b3164e6
VITE_USDT_ADDRESS=0x04c89607413713ec9775e14b954286519d836fef

VITE_ENABLE_PAYMASTER=false

# Optional: Anvil dev funder for “Fund 2 ETH” in Wallet Profile (global-setup also injects Anvil #1 for passkey E2E)
# VITE_LOCAL_DEV_FUNDER_PRIVATE_KEY=
VITE_LOCAL_DEV_FUNDER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
VITE_RELAY_BOOTSTRAP_ADDR_DEV=/ip4/127.0.0.1/tcp/4102/ws/p2p/12D3KooWAJjbRkp8FPF5MKgMU53aUTxWkqvDrs4zc1VMbwRwfsbE
VITE_PUBSUB_TOPICS=todo._peer-discovery._p2p._pubsub
