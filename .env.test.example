# Playwright + `vite build --mode test` / `preview:test` — copy to `.env.test`
# Same AA contract addresses as local dev after you deploy to Anvil.
# Start: anvil, docker compose -f docker-compose.aa-local.yml up -d, forge scripts, then pnpm run preview:test
#
# libp2p-config uses VITE_RELAY_BOOTSTRAP_ADDR_DEV when MODE=test or DEV or VITE_NODE_ENV=development.
# (Plain production build uses VITE_RELAY_BOOTSTRAP_ADDR_PROD / VITE_SEED_NODES.)

VITE_CHAIN_ID=31337
VITE_RPC_URL=http://127.0.0.1:8545
VITE_BUNDLER_URL=http://127.0.0.1:4337

VITE_ENTRY_POINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108
VITE_IMPLEMENTATION_CONTRACT=
VITE_ESCROW_CONTRACT=
VITE_USDT_ADDRESS=

VITE_ENABLE_PAYMASTER=false

# Optional: Anvil dev funder for “Fund 2 ETH” in Wallet Profile (global-setup also injects Anvil #1 for passkey E2E)
# VITE_LOCAL_DEV_FUNDER_PRIVATE_KEY=
